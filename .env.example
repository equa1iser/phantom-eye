# Copy this file to .env before running docker-compose.
# The .env file is gitignored — never commit it.

# ── OpenTelemetry (used by the phantom-eye container) ────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=phantom-eye
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,host.name=phantom-server

# ── Optional: enable verbose OTEL SDK debug output ───────────────────────────
# OTEL_LOG_LEVEL=debug
